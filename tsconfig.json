{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",

    /* Strict checks (strict: true enables these, listed for clarity) */
    "strict": true,

    /* Additional strict checks beyond "strict" */
    "noUncheckedIndexedAccess": true,
    "noPropertyAccessFromIndexSignature": true,
    // "exactOptionalPropertyTypes": true, // disabled: conflicts with Convex's v.optional() types
    "noFallthroughCasesInSwitch": true,
    "noImplicitReturns": true,
    "noImplicitOverride": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "allowUnusedLabels": false,
    "allowUnreachableCode": false,
    "verbatimModuleSyntax": true,

    /* Module / Emit */
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "outDir": "dist",
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    }
  },
  "include": ["src", "convex", "tests"],
  "exclude": ["node_modules", "dist"]
}
